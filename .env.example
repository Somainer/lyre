# Lyre .env example — copy this to `.env` (gitignored) and fill in your values.
#
# Loading order (first hit wins per variable):
#   1. real shell env  (FOO=bar lyre serve  → highest priority)
#   2. .env in CWD
#   3. .env in repo root
#
# Lines starting with # are comments. Quotes are optional unless your value
# contains spaces.

# ────────────────────────────────────────────────────────────────────────────
# LLM provider credentials
# ────────────────────────────────────────────────────────────────────────────
# Set whichever providers you actually use. The model_registry.yaml decides
# which env var each model entry consults (see endpoint.auth_env there).

# Real Anthropic API key — used by anthropic.claude-* entries
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek API key — used by deepseek.* entries (Anthropic-compat endpoint)
DEEPSEEK_API_KEY=sk-...

# OPTIONAL: force every wakeup to use this exact model id, bypassing
# persona.model_preference. Handy for cheap testing.
# LYRE_MODEL_OVERRIDE=deepseek.deepseek-v4-flash

# ────────────────────────────────────────────────────────────────────────────
# Lyre runtime paths
# ────────────────────────────────────────────────────────────────────────────
# Defaults:
#   LYRE_DB_PATH        ~/.lyre/lyre.db
#   LYRE_OBJECT_STORE   ~/.lyre/object_store
# Useful for keeping demo state separate from your real DB:
# LYRE_DB_PATH=/tmp/lyre-demo/lyre.db
# LYRE_OBJECT_STORE=/tmp/lyre-demo/object_store

# ────────────────────────────────────────────────────────────────────────────
# Defaults / observability
# ────────────────────────────────────────────────────────────────────────────
# Fallback model when neither persona preference nor override resolves.
# (Q9: this is being phased out in favor of registry-based selection.)
# LYRE_DEFAULT_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────────────────────────────────
# Git identity Lyre uses inside per-task worktrees
# ────────────────────────────────────────────────────────────────────────────
# These get forwarded into shell_exec subprocesses via the env allowlist.
# GIT_AUTHOR_NAME=Lyre
# GIT_AUTHOR_EMAIL=lyre@yourdomain
# GIT_COMMITTER_NAME=Lyre
# GIT_COMMITTER_EMAIL=lyre@yourdomain
